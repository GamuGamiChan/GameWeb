---
import "../styles/index.css";
import Socials from "../components/socials.astro";
import WebBadges from "../components/webbadges.astro";
import Webrings from "../components/webrings.astro";
import Navbar from "../components/navbar.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
    name="description"
    content="Game's personal site — projects, socials, and random internet stuff."
    />
    <meta property="og:title" content="Game's Personal Site" />
    <meta property="og:description" content="Projects, socials, and random internet stuff." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://thapat.me/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <title>Game's Personal Site</title>
  </head>
  <body>

    <Navbar />

    <main class="about">

      <h1 class="accent">Hi, I'm Game</h1>
      <p class="intro">I do random things on the internet.</p>
      <p>
        I'm a high school student who does random stuff that I think is fun.
        You'll find me irl at school as the boy with the green/black glasses and a purple watch.
      </p>
      <p>
        This site is very barebone so far, but I plan to add more content in the future, maybe? I have no idea.
      </p>
      
      <Socials />
      <WebBadges />
    </main>
  </body>
</html>